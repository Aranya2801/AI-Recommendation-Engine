# ═══════════════════════════════════════════════════════════════════════════════
# AI Recommendation Engine — Environment Configuration
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000
SECRET_KEY=CHANGE_ME_MINIMUM_32_CHARS_SECRET_KEY

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...

# ── Models ────────────────────────────────────────────────────────────────────
PRIMARY_MODEL=gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Databases ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://recuser:recpass@localhost:5432/recengine
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=          # needed for Qdrant Cloud

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=recommendation-engine

# ── Recommendation ────────────────────────────────────────────────────────────
DEFAULT_TOP_K=20
DIVERSITY_LAMBDA=0.3
CACHE_TTL=300

# ── Features ──────────────────────────────────────────────────────────────────
ENABLE_LLM_RERANKING=true
ENABLE_KNOWLEDGE_GRAPH=true
ENABLE_RL_EXPLORATION=true
ENABLE_DRIFT_DETECTION=true
